# ─── Required: Stock Data ────────────────────────────────────────────────────
# Get a FREE Finnhub API key at https://finnhub.io/register (no credit card)
# Without this key the app falls back to Yahoo Finance (may rate-limit)
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── Required for AI Analysis ────────────────────────────────────────────────
# Get a free Gemini API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional: Watchlist Customization ───────────────────────────────────────
# Comma-separated list of ticker symbols (default shown below)
# WATCHLIST_SYMBOLS=AAPL,MSFT,GOOGL,NVDA,AMZN,META,TSLA,JPM,V,UNH

# ─── Optional: Twelve Data (RSI/MA indicators when Yahoo Finance rate-limits) ─
# Free key at https://twelvedata.com/pricing — no credit card needed
# Without this, indicators show defaults until Yahoo Finance rate-limit resets.
# TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# ─── Optional: Alpha Vantage (enhanced news) ─────────────────────────────────
# Get a free key at https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ─── App Config ──────────────────────────────────────────────────────────────
# For production deployment, set to your domain
# NEXT_PUBLIC_APP_URL=https://your-domain.com
